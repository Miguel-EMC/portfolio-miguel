{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "portfolio": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "apps/portfolio",
      "sourceRoot": "apps/portfolio/src",
      "prefix": "app",
      "i18n": {
        "sourceLocale": "en",
        "locales": {
          "es": {
            "translation": "apps/portfolio/src/locale/messages.es.xlf",
            "baseHref": ""
          }
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/portfolio",
            "index": "apps/portfolio/src/index.html",
            "browser": "apps/portfolio/src/main.ts",
            "polyfills": [
              "zone.js",
              "@angular/localize/init"
            ],
            "tsConfig": "apps/portfolio/tsconfig.app.json",
            "assets": [
              "apps/portfolio/src/favicon.ico",
              "apps/portfolio/src/assets",
              "apps/portfolio/src/404.html",
              "apps/portfolio/src/googleab23b079823d4a4f.html",
              "apps/portfolio/src/sitemap.xml",
              "apps/portfolio/src/robots.txt"
            ],
            "styles": [
              "node_modules/ngx-toastr/toastr.css",
              "node_modules/highlight.js/styles/atom-one-dark.css",
              "apps/portfolio/src/styles.scss",
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "node_modules/bootstrap-icons/font/bootstrap-icons.min.css"
            ],
            "scripts": [
              "node_modules/bootstrap/dist/js/bootstrap.bundle.min.js"
            ],
            "server": "apps/portfolio/src/main.server.ts",
            "prerender": false,
            "ssr": false
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "apps/portfolio/src/environments/environment.ts",
                  "with": "apps/portfolio/src/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1mb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "50kb",
                  "maximumError": "60kb"
                }
              ],
              "outputHashing": "all"
            },
            "demo": {
              "fileReplacements": [
                {
                  "replace": "apps/portfolio/src/environments/environment.ts",
                  "with": "apps/portfolio/src/environments/environment.demo.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "portfolio:build:production"
            },
            "development": {
              "buildTarget": "portfolio:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "community": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "apps/community",
      "sourceRoot": "apps/community/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/community",
            "index": "apps/community/src/index.html",
            "browser": "apps/community/src/main.ts",
            "polyfills": [
              "zone.js",
              "@angular/localize/init"
            ],
            "tsConfig": "apps/community/tsconfig.app.json",
            "assets": [
              "apps/community/src/favicon.ico",
              "apps/community/src/assets"
            ],
            "styles": [
              "node_modules/ngx-toastr/toastr.css",
              "node_modules/highlight.js/styles/atom-one-dark.css",
              "apps/community/src/styles.scss",
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "node_modules/bootstrap-icons/font/bootstrap-icons.min.css"
            ],
            "scripts": [
              "node_modules/bootstrap/dist/js/bootstrap.bundle.min.js"
            ],
            "server": "apps/community/src/main.server.ts",
            "prerender": false,
            "ssr": false
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "apps/community/src/environments/environment.ts",
                  "with": "apps/community/src/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1mb",
                  "maximumError": "2mb"
                }
              ],
              "outputHashing": "all"
            },
            "demo": {
              "fileReplacements": [
                {
                  "replace": "apps/community/src/environments/environment.ts",
                  "with": "apps/community/src/environments/environment.demo.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "community:build:production"
            },
            "development": {
              "buildTarget": "community:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
